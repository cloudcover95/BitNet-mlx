\f3\fs26 \cf0 def compile_manifold(self, model_id_or_path: str, output_dir: str):\
    if os.path.exists(model_id_or_path):\
        src_path = Path(model_id_or_path)\
    else:\
        logger.info(f"[*] Resolving Remote HF Manifold: \{model_id_or_path\}")\
        src_path = Path(snapshot_download(repo_id=model_id_or_path, local_dir_use_symlinks=False))\
\
    dest_path = Path(output_dir)\
    os.makedirs(dest_path, exist_ok=True)\
    \
    logger.info(f"[*] Igniting Rank-Aware AbsMean PTQ Compilation on: \{src_path\}")\
    t0 = time.perf_counter()\
    \
    for ext in ["*.json", "*.model", "*.txt"]:\
        for file in src_path.glob(ext):\
            if "safetensors.index" not in file.name: \
                shutil.copy(file, dest_path / file.name)\
\
    st_files = list(src_path.glob("*.safetensors"))\
    if not st_files:\
        logger.error("[-] Fatal: Zero Safetensors located.")\
        return\
\
    total_fidelity, layers_processed = 0.0, 0\
    total_orig_mb, total_quant_mb = 0.0, 0.0\
\
    for shard in st_files:\
        logger.info(f"[*] Quantizing Shard: \{shard.name\}")\
        weights = mx.load(str(shard))\
        ternary_dict = \{\}\
        for name, tensor in weights.items():\
            if "weight" in name and len(tensor.shape) == 2 and not any(k in name.lower() for k in self.exclude_layers):\
                base_name = name.rsplit('.weight', 1)[0]\
                w_q, gamma = compute_channel_ternary(tensor)\
                mx.eval(w_q, gamma)\
                \
                # Compute Value Metrics\
                metrics = C2VMetrics.compute_savings(tensor.shape)\
                total_orig_mb += metrics["original_mb"]\
                total_quant_mb += metrics["quantized_mb"]\
                \
                # Evaluate Spectral Fidelity\
                fid = SpectralEvaluator.evaluate_rank_fidelity(tensor, w_q, gamma)\
                total_fidelity += fid\
                layers_processed += 1\
\
                ternary_dict[f"\{base_name\}.w_q"], ternary_dict[f"\{base_name\}.gamma"] = w_q, gamma\
            else:\
                ternary_dict[name] = tensor\
                \
        if hasattr(mx, 'clear_cache'): mx.clear_cache()\
        mx.save_safetensors(str(dest_path / shard.name), ternary_dict)\
\
    avg_fid = (total_fidelity / max(1, layers_processed)) * 100\
    logger.info(f"\\n[+] Compilation Complete (\{time.perf_counter()-t0:.2f\}s).")\
    logger.info(f"[+] C2V Economy: \{total_orig_mb:.1f\}MB -> \{total_quant_mb:.1f\}MB")\
    logger.info(f"[+] Spectral Fidelity Retained: \{avg_fid:.2f\}%")\
    logger.info(f"[+] Secure Matrix generated at \{output_dir\}")\
