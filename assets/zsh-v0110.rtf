@mx.compile def compute_channel_ternary(w: mx.array) -> tuple: """ Computes absolute-mean ternary projection. gamma = 1/N sum(|W_row|) W_q = round(clip(W/gamma, -1, 1)) """ eps = 1e-5 gamma = mx.mean(mx.abs(w), axis=-1, keepdims=True) w_q = mx.round(mx.clip(w / (gamma + eps), -1.0, 1.0)) return w_q.astype(mx.int8), gamma\
@mx.compile def fused_ternary_matmul(x: mx.array, w_q: mx.array, gamma: mx.array, q_max: float = 127.0) -> mx.array: """ AMX-Optimized MatMul. Executes INT8 accumulation before returning to FP16 domain via hardware scale parameters. """ eps = 1e-5 g_x = mx.max(mx.abs(x), axis=-1, keepdims=True) x_q = mx.clip(mx.round(x * (q_max / (g_x + eps))), -q_max, q_max)\
