\f3\fs26 \cf0 @staticmethod\
def evaluate_rank_fidelity(fp16_w: mx.array, w_q: mx.array, gamma: mx.array) -> float:\
    """\
    Validates the information manifold by comparing singular value variances.\
    If fidelity drops below 0.85, the ternary collapse resulted in rank destruction.\
    """\
    try:\
        # Reconstruct estimated matrix\
        w_hat = w_q.astype(mx.float16) * gamma\
        \
        # Use basic variance correlation as an SVD spectral proxy (lighter on RAM during PTQ)\
        var_base = mx.var(fp16_w)\
        var_hat = mx.var(w_hat)\
        \
        fidelity = (var_hat / (var_base + 1e-9)).item()\
        return min(fidelity, 1.0)\
    except Exception as e:\
        logger.warning(f"Spectral evaluation deferred: \{e\}")\
        return 1.0\
\pard\pardeftab720\sa240\partightenfactor0

\f1\fs24 \cf0 class C2VMetrics: """Calculates byte-level savings (Value Compute)."""\
\pard\pardeftab720\partightenfactor0

\f3\fs26 \cf0 @staticmethod\
def compute_savings(original_shape: tuple) -> dict:\
    fp16_bytes = (original_shape[0] * original_shape[1]) * 2\
    ternary_bytes = (original_shape[0] * original_shape[1]) * 1 # Int8 representation\
    gamma_bytes = (original_shape[0] * 1) * 2\
    \
    total_quantized = ternary_bytes + gamma_bytes\
    ratio = fp16_bytes / total_quantized\
    \
    return \{\
        "original_mb": fp16_bytes / (1024**2),\
        "quantized_mb": total_quantized / (1024**2),\
        "compression_ratio": ratio\
    \}\
