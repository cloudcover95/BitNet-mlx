import mlx.core as mx\
import numpy as np\
import io\
\
class BinaryRPC:\
    """Binary-packed tensor serialization for O(N) network throughput."""\
    @staticmethod\
    def pack_tensor(t: mx.array) -> bytes:\
        arr = np.array(t)\
        bio = io.BytesIO()\
        np.save(bio, arr)\
        return bio.getvalue()\
\
    @staticmethod\
    def unpack_tensor(data: bytes) -> mx.array:\
        bio = io.BytesIO(data)\
        return mx.array(np.load(bio))\
EOF\
