@mx.compile def compute_channel_ternary(w: mx.array, eps: float = 1e-5) -> tuple: """ Computes absolute-mean ternary projection. Maps parameters to \{-1, 0, 1\} with dynamic per-row scaling fields. """ gamma = mx.mean(mx.abs(w), axis=-1, keepdims=True) w_q = mx.round(mx.clip(w / (gamma + eps), -1.0, 1.0)) return w_q.astype(mx.int8), gamma\
@mx.compile def compute_activation_quantization(x: mx.array, eps: float = 1e-5) -> tuple: """ Performs absolute-maximum (absmax) 8-bit quantization on incoming activations. """ g_x = mx.max(mx.abs(x), axis=-1, keepdims=True) x_q = mx.clip(mx.round(x * (127.0 / (g_x + eps))), -127.0, 127.0) return x_q.astype(mx.int8), g_x\
@mx.compile def fused_ternary_matmul(x_q: mx.array, g_x: mx.array, w_q: mx.array, gamma: mx.array) -> mx.array: """ Executes pure integer accumulation routing on AMX before dequantizing back to FP16. """ y_q = mx.matmul(x_q.astype(mx.int16), w_q.T.astype(mx.int16)) return y_q.astype(mx.float16) * ((gamma.T * g_x) / 127.0)\
class DynamicBitLinear(nn.Module): """Drop-in MLX Linear transformation replacement layer.""" def 
