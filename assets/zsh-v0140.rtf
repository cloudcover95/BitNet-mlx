    noise = mx.random.normal(self.fp32_proxy.shape) * 0.01 * mx.std(self.fp32_proxy)\
    perturbed_w = self.fp32_proxy + noise\
    w_q_pert, gamma_pert = compute_channel_ternary(perturbed_w)\
    pert_recon = w_q_pert.astype(mx.float16) * gamma_pert\
    pert_diff = mx.mean(mx.abs(perturbed_w - pert_recon)).item()\
    logger.info(f" | 1% Perturbation Delta: \{pert_diff:.5f\} (Verifies Training Rigidity)")\
\
    # 5% Outlier Sparsification Test\
    sparsified_w = mx.where(mx.abs(self.fp32_proxy) > (mx.std(self.fp32_proxy) * 2), 0.0, self.fp32_proxy)\
