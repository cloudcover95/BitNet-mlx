\f3\fs26 \cf0 def compile_manifold(self, model_id_or_path: str, output_dir: str):\
    if os.path.exists(model_id_or_path):\
        src_path = Path(model_id_or_path)\
    else:\
        logger.info(f"[*] Querying distributed registries for: \{model_id_or_path\}")\
        src_path = Path(snapshot_download(repo_id=model_id_or_path, local_dir_use_symlinks=False))\
\
    dest_path = Path(output_dir)\
    os.makedirs(dest_path, exist_ok=True)\
    t0 = time.perf_counter()\
    \
    for ext in ["*.json", "*.model", "*.txt"]:\
        for file in src_path.glob(ext):\
            if "safetensors.index" not in file.name:\
                shutil.copy(file, dest_path / file.name)\
\
    st_files = list(src_path.glob("*.safetensors"))\
    total_fidelity, layers_processed = 0.0, 0\
    total_orig_bytes, total_quant_bytes = 0, 0\
\
    for shard in st_files:\
        logger.info(f"[*] Compiling data shard: \{shard.name\}")\
        weights = mx.load(str(shard))\
        ternary_dict = \{\}\
        \
        for name, tensor in weights.items():\
            if "weight" in name and len(tensor.shape) == 2 and not any(k in name.lower() for k in self.exclude_layers):\
                base_name = name.rsplit('.weight', 1)[0]\
                w_q, gamma = compute_channel_ternary(tensor)\
                mx.eval(w_q, gamma)\
                \
                orig_b = tensor.size * 2\
                quant_b = (w_q.size * 1) + (gamma.size * 2)\
                total_orig_bytes += orig_b\
                total_quant_bytes += quant_b\
                \
                fid = StructuralEvaluator.evaluate_variance_fidelity(tensor, w_q, gamma)\
                total_fidelity += fid\
                layers_processed += 1\
\
                self.hd_logger.append_layer_telemetry(name, tensor.shape, fid, float(orig_b) / float(quant_b))\
                ternary_dict[f"\{base_name\}.w_q"] = w_q\
                ternary_dict[f"\{base_name\}.gamma"] = gamma\
            else:\
                ternary_dict[name] = tensor\
                \
        mx.save_safetensors(str(dest_path / shard.name), ternary_dict)\
\
    self.hd_logger.commit_to_disk()\
    logger.info(f"\\n[+] Compiler Execution Finished (\{time.perf_counter()-t0:.2f\}s).")\
    logger.info(f"[+] Memory footprint: \{total_orig_bytes/(1024**2):.2f\} MB -> \{total_quant_bytes/(1024**2):.2f\} MB")\
    logger.info(f"[+] Variance Retained (SVD Bypassed): \{(total_fidelity / max(1, layers_processed)) * 100:.2f\}%")\
