\f1\b0\fs24 \cf0 cat << 'EOF' > src/bitnet_mlx/bitnet_layers.py import mlx.core as mx import mlx.nn as nn\
@mx.compile def compute_hybrid_ternary_ste(w: mx.array, eps: float = 1e-5) -> tuple: """ QAT-ready Hybrid Ternary Mapping with Straight-Through Estimator (STE). Routes gradients through non-differentiable discrete boundaries. """ outlier_cutoff = 3.0 * mx.std(w) outlier_mask = mx.abs(w) > outlier_cutoff\
\pard\pardeftab720\partightenfactor0

\f3\fs26 \cf0 # Isolate Core Matrix\
w_core = mx.where(outlier_mask, 0.0, w)\
gamma = mx.mean(mx.abs(w_core), axis=-1, keepdims=True)\
\
# Non-differentiable quantization\
w_q_raw = mx.round(mx.clip(w_core / (gamma + eps), -1.0, 1.0))\
\
# STE: Forward pass uses w_q_raw, backward pass uses w_core gradients\
w_q_ste = w_core + mx.stop_gradient(w_q_raw - w_core)\
\
w_outliers = mx.where(outlier_mask, w, 0.0)\
\
return w_q_ste.astype(mx.float16), gamma, w_outliers.astype(mx.float16)\
\pard\pardeftab720\sa240\partightenfactor0

\f1\fs24 \cf0 class DynamicBitLinear(nn.Module): """Bidirectional execution layer for QAT and stateless inference.""" def 
\f2\b init
\f1\b0 (self, in_d: int, out_d: int, bias: bool = False, activation_bits: int = 8): super().
\f2\b init
\f1\b0 () self.bits = activation_bits # Keep underlying weights in FP16 for continuous gradient accumulation self.weight = mx.random.normal((out_d, in_d), dtype=mx.float16) * 0.02 if bias: self.bias = mx.zeros((out_d,), dtype=mx.float16)\
\pard\pardeftab720\partightenfactor0

\f3\fs26 \cf0 def __call__(self, x: mx.array) -> mx.array:\
    w_q_ste, gamma, w_outliers = compute_hybrid_ternary_ste(self.weight)\
    \
    # Dynamic Activation Quantization\
    q_max = (2 ** (self.bits - 1)) - 1.0\
    g_x = mx.max(mx.abs(x), axis=-1, keepdims=True)\
    x_q = mx.clip(mx.round(x * (q_max / (g_x + 1e-5))), -q_max, q_max)\
    x_q_ste = x + mx.stop_gradient(x_q - x)\
\
    # Fused accumulation via STE tensors\
    y_core = mx.matmul(x_q_ste, w_q_ste.T) * ((gamma.T * g_x) / q_max)\
    y_outliers = mx.matmul(x, w_outliers.T)\
    \
    y = y_core + y_outliers\
    if hasattr(self, 'bias') and getattr(self, 'bias') is not None:\
        y += self.bias\
    return y\
