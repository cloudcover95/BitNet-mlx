import psutil\
import logging\
\
logger = logging.getLogger("BitNet.PowerMatrix")\
\
class ThermalSubstrate:\
    """Monitors local edge hardware for 48V power anomalies and thermal throttling."""\
    \
    @staticmethod\
    def query_thermal_state() -> str:\
        """\
        Polls logic board metrics. Returns optimal activation depth.\
        Fallback to standard a8 if sensor data is restricted by Apple SOC sandbox.\
        """\
        try:\
            cpu_percent = psutil.cpu_percent(interval=0.1)\
            if cpu_percent > 85.0:\
                return "a4" # Shift to INT4 activations to reduce logic board stress\
            return "a8"     # Maintain standard INT8 pipeline\
        except Exception:\
            return "a8"\
