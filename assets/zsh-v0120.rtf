\f3\fs26 \cf0 def _apply_calibration_filter(self, tensor: mx.array) -> mx.array:\
    """\
    Isolates pathological structural outliers by truncating standard deviations \
    beyond extreme thresholds prior to applying absolute-mean mapping.\
    """\
    std = mx.std(tensor)\
    mean = mx.mean(tensor)\
    bound = 3.0 * std\
    return mx.clip(tensor, mean - bound, mean + bound)\
\
def compile_manifold(self, model_id_or_path: str, output_dir: str):\
    if os.path.exists(model_id_or_path):\
        src_path = Path(model_id_or_path)\
    else:\
        logger.info(f"[*] Querying distributed HF registry for: \{model_id_or_path\}")\
        src_path = Path(snapshot_download(repo_id=model_id_or_path, local_dir_use_symlinks=False))\
\
    dest_path = Path(output_dir)\
    os.makedirs(dest_path, exist_ok=True)\
    \
    logger.info(f"[*] Initializing Rank-Aware AbsMean Substrate Compiler over: \{src_path\}")\
    t0 = time.perf_counter()\
    \
    for ext in ["*.json", "*.model", "*.txt"]:\
        for file in src_path.glob(ext):\
            if "safetensors.index" not in file.name:\
                shutil.copy(file, dest_path / file.name)\
\
    st_files = list(src_path.glob("*.safetensors"))\
    if not st_files:\
        logger.error("[-] Fatal: No standard safetensors objects found in root manifold path.")\
        return\
\
    total_fidelity, layers_processed = 0.0, 0\
    total_orig_bytes, total_quant_bytes = 0, 0\
\
    for shard in st_files:\
        logger.info(f"[*] Processing data stream split: \{shard.name\}")\
        weights = mx.load(str(shard))\
        ternary_dict = \{\}\
        \
        for name, tensor in weights.items():\
            if "weight" in name and len(tensor.shape) == 2 and not any(k in name.lower() for k in self.exclude_layers):\
                base_name = name.rsplit('.weight', 1)[0]\
                \
                working_tensor = tensor\
                if self.clip_outliers:\
                    working_tensor = self._apply_calibration_filter(tensor)\
\
                w_q, gamma = compute_channel_ternary(working_tensor)\
                mx.eval(w_q, gamma)\
                \
                # Track byte delta mapping profiles\
                orig_b = tensor.size * 2\
                quant_b = (w_q.size * 1) + (gamma.size * 2)\
                total_orig_bytes += orig_b\
                total_quant_bytes += quant_b\
                comp_ratio = float(orig_b) / float(quant_b)\
                \
                # Evaluate topological fidelity matrix\
                fid = SpectralEvaluator.evaluate_rank_fidelity(tensor, w_q, gamma)\
                total_fidelity += fid\
                layers_processed += 1\
\
                self.hd_logger.append_layer_telemetry(name, tensor.shape, fid, comp_ratio)\
                ternary_dict[f"\{base_name\}.w_q"] = w_q\
                ternary_dict[f"\{base_name\}.gamma"] = gamma\
            else:\
                ternary_dict[name] = tensor\
                \
        if hasattr(mx, 'clear_cache'): mx.clear_cache()\
        mx.save_safetensors(str(dest_path / shard.name), ternary_dict)\
\
    self.hd_logger.commit_to_disk()\
    \
    avg_fid = (total_fidelity / max(1, layers_processed)) * 100\
    orig_mb = total_orig_bytes / (1024**2)\
    quant_mb = total_quant_bytes / (1024**2)\
    \
    logger.info(f"\\n[+] Production Compiling Execution Terminated (\{time.perf_counter()-t0:.2f\}s).")\
    logger.info(f"[+] Thermodynamic Volume Adjust: \{orig_mb:.2f\} MB -> \{quant_mb:.2f\} MB")\
    logger.info(f"[+] Total System Spectral Rank Preserved: \{avg_fid:.2f\}%")\
