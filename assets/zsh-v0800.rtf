def fused_ternary_matmul(x_q: mx.array, g_x: mx.array, w_q: mx.array, gamma: mx.array) -> mx.array:\
y_q = mx.matmul(x_q.astype(mx.int16), w_q.T.astype(mx.int16))\
return y_q.astype(mx.float16) * ((gamma.T * g_x) / 127.0)\
