@mx.compile\
def compute_channel_ternary(w: mx.array, eps: float = 1e-5) -> tuple:\
"""Absolute-mean ternary scaling. Preserves structural variance in O(N)."""\
gamma = mx.mean(mx.abs(w), axis=-1, keepdims=True)\
scaled = w / (gamma + eps)\
w_q = mx.round(mx.clip(scaled, -1.0, 1.0))\
return w_q.astype(mx.int8), gamma\
@mx.compile\
def compute_activation_quantization(x: mx.array, bits: int = 8, eps: float = 1e-5) -> tuple:\
"""Dynamic INT8/INT4 state projection for sequence activations."""\
q_max = (2 (bits - 1)) - 1.0\
g_x = mx.max(mx.abs(x), axis=-1, keepdims=True)\
x_q = mx.clip(mx.round(x * (q_max / (g_x + eps))), -q_max, q_max)\
return x_q.astype(mx.int8), g_x\
